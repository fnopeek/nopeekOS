# nopeek microvm Linux — config overlay on top of x86_64_defconfig.
#
# Goal: minimal Linux that boots in our hypervisor (no ACPI, no APIC,
# no PCI MSI, just 8250 serial + virtio-pci legacy IRQ) AND has all
# the virtio drivers we need BUILT-IN (so our raw-syscall PID-1
# doesn't need a module loader).
#
# Applied via `scripts/kconfig/merge_config.sh` after `make
# x86_64_defconfig`. Only put OVERRIDES here — anything we don't
# explicitly mention keeps the defconfig default.

# ── Identity ───────────────────────────────────────────────────────
CONFIG_LOCALVERSION="-nopeek"
# CONFIG_LOCALVERSION_AUTO is not set

# ── Compression ───────────────────────────────────────────────────
# Stick with gzip — small, fast decompress.
CONFIG_KERNEL_GZIP=y
# CONFIG_KERNEL_LZMA is not set
# CONFIG_KERNEL_XZ is not set
# CONFIG_KERNEL_LZO is not set
# CONFIG_KERNEL_LZ4 is not set
# CONFIG_KERNEL_ZSTD is not set

# ── virtio: ALL built-in ───────────────────────────────────────────
# This is the whole point — virtio_blk must be in the bzImage so the
# raw-syscall PID-1 can use /dev/vda without modprobe.
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_PCI_LEGACY=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_VIRTIO_INPUT=y
CONFIG_VIRTIO_MMIO=y

# ── Console ────────────────────────────────────────────────────────
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_EARLYCON=y
CONFIG_PRINTK=y
CONFIG_PRINTK_TIME=y

# ── PCI ───────────────────────────────────────────────────────────
CONFIG_PCI=y
# We don't emulate MSI/MSI-X yet (12.2.3+). Legacy INTx only.
# CONFIG_PCI_MSI is not set

# ── Filesystems ───────────────────────────────────────────────────
CONFIG_EXT4_FS=y
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# ── initramfs ─────────────────────────────────────────────────────
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y

# ── Network (minimal — exercise later in 12.3) ────────────────────
CONFIG_NET=y
CONFIG_INET=y
CONFIG_UNIX=y
CONFIG_PACKET=y

# ── Drop hardware we definitely don't have in the MicroVM ─────────
# CONFIG_USB_SUPPORT is not set
# CONFIG_SOUND is not set
# CONFIG_DRM is not set
# CONFIG_FB is not set
# CONFIG_HID is not set
# CONFIG_INPUT_MOUSEDEV is not set
# CONFIG_INPUT_KEYBOARD is not set
# CONFIG_BT is not set
# CONFIG_WLAN is not set
# CONFIG_WIRELESS is not set
# CONFIG_RFKILL is not set
# CONFIG_THERMAL is not set
# CONFIG_WATCHDOG is not set

# ── ACPI off (we don't emulate ACPI tables) ──────────────────────
# defconfig has CONFIG_ACPI=y; cmdline `acpi=off` disables it at runtime
# but the code still gets compiled in. Stripping it shrinks the kernel
# noticeably. Only safe because we're a controlled microvm guest.
# CONFIG_ACPI is not set

# ── Drop SMP — we run 1 vCPU for now ─────────────────────────────
# CONFIG_SMP is not set

# ── Drop crypto/security overhead we don't need in a microvm guest ─
# CONFIG_AUDIT is not set
# CONFIG_SECURITY is not set
# CONFIG_INTEGRITY is not set
# CONFIG_LANDLOCK is not set
