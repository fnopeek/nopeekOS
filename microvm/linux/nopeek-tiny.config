# nopeekOS MicroVM — Linux Kernel Config Skeleton
#
# Target:  Linux 6.18 LTS, x86_64, KVM guest
# Base:    `make tinyconfig` (then incrementally enable below)
# Spec:    PHASE12_MICROVM.md (repo root)
#
# Each section is annotated with the Phase 12.x milestone it
# enables. Symbols come in as the milestones land.
#
# Format is standard Kconfig: `CONFIG_FOO=y`, `CONFIG_FOO=m`,
# `# CONFIG_FOO is not set`. Bare `#` is a free-form comment.
#
# Pinned in the per-app Recipe:
#   linux_lts_branch     = "6.18"
#   linux_patch          = "6.18.X"
#   linux_tarball_blake3 = "0x..."
#
# This file is the "policy" — what shall be on/off. The exact
# Kconfig symbols may shift between minor versions; resolve via
# `make olddefconfig` against the pinned 6.18.X tarball at build
# time.
# ============================================================


#
# Architecture & base — Phase 12.1 (Hello Bash)
#
CONFIG_64BIT=y
CONFIG_X86_64=y

# Single VCPU for 12.1 (Hello Bash). Flip to =y for 12.6 Firefox.
# CONFIG_SMP is not set

# We are the guest, not the host hypervisor.
CONFIG_HYPERVISOR_GUEST=y
CONFIG_PARAVIRT=y
CONFIG_KVM_GUEST=y
CONFIG_PARAVIRT_SPINLOCKS=y


#
# PCI transport — required by virtio-pci (default virtio binding)
#
CONFIG_PCI=y
CONFIG_PCI_MMCONFIG=y


#
# Console / serial — Phase 12.1 (Hello Bash)
#
# virtio-console is the ONLY I/O channel for 12.1. No VGA, no
# tty1..6, no kernel framebuffer console.
#
CONFIG_PRINTK=y
CONFIG_TTY=y
# CONFIG_VT is not set
# CONFIG_FB is not set
# CONFIG_LOGO is not set

CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_PCI_LEGACY=y
CONFIG_VIRTIO_CONSOLE=y


#
# Memory / process primitives — Phase 12.1
#
CONFIG_MMU=y
CONFIG_FUTEX=y
CONFIG_EPOLL=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_SIGNALFD=y
CONFIG_AIO=y


#
# Init / initramfs — Phase 12.1
#
# Initramfs hosts our Rust PID-1 (~50 KB statisch) plus the App-
# Binary out of the squashfs read-only mount. Path filled by build
# pipeline.
#
CONFIG_BLK_DEV_INITRD=y
CONFIG_INITRAMFS_SOURCE=""
CONFIG_RD_GZIP=y
# CONFIG_RD_BZIP2 is not set
# CONFIG_RD_LZMA is not set
# CONFIG_RD_XZ is not set
# CONFIG_RD_LZO is not set
# CONFIG_RD_LZ4 is not set
# CONFIG_RD_ZSTD is not set


#
# Filesystems — Phase 12.1
#
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y


#
# Random / entropy — Phase 12.1
#
# Pulled from host CSPRNG via virtio-rng (jitter via
# rng-tools/random in userspace if needed).
#
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_VIRTIO=y


# ============================================================
# 12.2 — virtio-blk + encrypted ext4 profile-image
# ============================================================
#
# Block I/O backend that the host's virtio-blk-Backend feeds with
# decrypted blocks (ChaCha20-Poly1305 unwrap host-side, Guest
# sees plain ext4).
#
CONFIG_BLOCK=y
CONFIG_BLK_DEV=y
CONFIG_VIRTIO_BLK=y

# squashfs for the read-only Container.sqfs (12.2 needs this for
# the rootfs mount, 12.1 lives entirely in initramfs).
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_ZSTD=y
CONFIG_SQUASHFS_ZLIB=y
# CONFIG_SQUASHFS_LZ4 is not set
# CONFIG_SQUASHFS_LZO is not set
# CONFIG_SQUASHFS_XZ is not set

CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
# CONFIG_EXT4_FS_POSIX_ACL is not set
# CONFIG_EXT4_FS_SECURITY is not set


# ============================================================
# 12.3 — virtio-net + cap-filter (host-side)
# ============================================================
#
# Cap-filter is host-side (whitelist im Manifest). Kein iptables
# im Guest — der Guest hat überhaupt keine Filter-Awareness.
#
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_NETDEVICES=y
CONFIG_NET_CORE=y
CONFIG_VIRTIO_NET=y
# CONFIG_NETFILTER is not set
# CONFIG_BRIDGE is not set
# CONFIG_VLAN_8021Q is not set


# ============================================================
# 12.4 — virtio-gpu (cross-domain) + virtio-input + Wayland
# ============================================================
#
# Display path: virtio-gpu cross-domain context (mainline ≥ 5.16,
# voll im 6.18). Wayland-Passthrough auf virgl-Protocol-Level.
# DRM native context als Performance-Upgrade-Pfad ab 12.6+ wenn
# 6.18-Patch-Reife stimmt — derzeit als TBD-Section markiert.
#
CONFIG_DRM=y
CONFIG_DRM_VIRTIO_GPU=y
# CONFIG_DRM_VIRTIO_GPU_KMS — auto, leave default
# CONFIG_DRM_FBDEV_EMULATION is not set    # no console emulation

# virtio-input für Maus/Tastatur aus Shade
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_VIRTIO_INPUT=y
# CONFIG_KEYBOARD_ATKBD is not set
# CONFIG_MOUSE_PS2 is not set


# ============================================================
# 12.5+ — virtiofs (Pattern B Subtree-Mount, opt-in pro App)
# ============================================================
#
# Erst aktivieren wenn IDE/File-Manager-Use-Cases real werden.
# Default-Apps (Browser, Mail, Player) brauchen Pattern A
# (Picker), nicht Pattern B.
#
# CONFIG_VIRTIO_FS is not set
# CONFIG_FUSE_FS is not set


# ============================================================
# 12.6+ — TBD: DRM native context, multi-VCPU, GPU performance
# ============================================================
#
# Aktivieren wenn 6.18-Patch-Reife stimmt und Browser-Performance
# spürbar profitiert. Per-App im Manifest (`display.mode =
# "drm-native"`) statt globalem Default.
#
# CONFIG_DRM_NATIVE_CONTEXT_* — TBD, Symbol-Namen finalisieren
#                              gegen 6.18.X tarball
#
# Multi-VCPU: CONFIG_SMP=y oben + entsprechende SMP/scheduler bits


# ============================================================
# Explizit AUS — nicht auf den Pfad zurückkommen ohne Rückfrage
# ============================================================
#
# Module loading: alles built-in, kein modprobe im Guest.
# Vereinfacht Build, schließt LKM-basierte Persistence aus.
#
# CONFIG_MODULES is not set

# Kein USB im Guest — Hardware-Passthrough für USB ist explizit
# nicht Teil von Phase 12.
#
# CONFIG_USB_SUPPORT is not set
# CONFIG_USB is not set

# Audio kommt via eigene virtio-Bridge in einer späteren Phase,
# nicht via ALSA-Stack im Guest.
#
# CONFIG_SOUND is not set

# Kein klassischer Block-Layer-Crypto (LUKS/dm-crypt) — der Host
# entschlüsselt vor virtio-blk, der Guest sieht plain ext4.
#
# CONFIG_DM_CRYPT is not set
# CONFIG_BLK_DEV_DM is not set

# Kein Debug-/Profiling-Stack im Production-Image. Wenn wir mal
# einen Debug-Container brauchen, ist das ein separates Recipe.
#
# CONFIG_DEBUG_KERNEL is not set
# CONFIG_KALLSYMS is not set
# CONFIG_FTRACE is not set
# CONFIG_PROFILING is not set
# CONFIG_KPROBES is not set
# CONFIG_PERF_EVENTS is not set

# Keine Power-Management-Komplexität — VM ist always-on solange
# der Manager sie laufen lässt. Stop ist ein Host-Trigger.
#
# CONFIG_SUSPEND is not set
# CONFIG_HIBERNATION is not set
# CONFIG_PM_SLEEP is not set

# Keine Filesystem-Auswahl ausser was wir oben erlaubt haben.
#
# CONFIG_EXT2_FS is not set
# CONFIG_XFS_FS is not set
# CONFIG_BTRFS_FS is not set
# CONFIG_F2FS_FS is not set
# CONFIG_REISERFS_FS is not set
# CONFIG_NFS_FS is not set
# CONFIG_CIFS is not set


# ============================================================
# Build-Pipeline-Verträge (informativ, kein Kconfig)
# ============================================================
#
# - `make tinyconfig && cat nopeek-tiny.config >> .config &&
#    make olddefconfig` ist der canonical resolution-step.
# - Output-Validation: jedes `=y` aus diesem File MUSS in der
#   resolved .config ebenfalls `=y` sein. Wenn `olddefconfig`
#   ein Symbol auf `n` zwingt (Dependency fehlt), ist das ein
#   Build-Fail, kein silent drift.
# - `# ... is not set` Lines werden ebenso geprüft — wenn ein
#   "AUS"-Symbol in der resolved config auftaucht, Fail.
# - Resolution ist deterministisch gegen den gepinnten 6.18.X
#   tarball + diese Datei. Gleicher Input → gleiches Output.
